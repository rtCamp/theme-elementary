{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "rtcamp/button",
	"title": "Button (rtCamp)",
	"category": "design",
	"icon": "button",
	"description": "A button block.",
	"attributes": {
		"label": {
			"type": "string",
			"default": "Get started"
		},
		"url": {
			"type": "string",
			"default": ""
		},
		"variant": {
			"type": "string",
			"default": "primary"
		},
		"size": {
			"type": "string",
			"default": "medium"
		},
		"class": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./edit.js",
	"viewScript": "file:./view.js",
	"render": "file:./render.php"
}
