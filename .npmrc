save-exact = true

; --- Private distribution during the pilot ---------------------------------
; @rtcamp/wp-tooling is served from GitHub Packages (published "restricted",
; i.e. private to the rtCamp org) until it ships on the public npm registry.
; Installing it needs a GitHub token with read:packages, supplied via the
; GITHUB_TOKEN env var (org users in ~/.npmrc, CI as a secret).
;
; TODO(public-release): once @rtcamp/wp-tooling is published to the public npm
; registry, delete the two lines below so it resolves from registry.npmjs.org
; like any other dependency. No code change is needed, only this config.
@rtcamp:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
